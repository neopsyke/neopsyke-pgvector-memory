# Provider runtime
MEMORY_PROVIDER_TRANSPORT=http
MEMORY_PROVIDER_HTTP_HOST=127.0.0.1
MEMORY_PROVIDER_HTTP_PORT=7841

# Embeddings
MISTRAL_API_KEY=
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=mistral-embed
EMBEDDING_DIMENSIONS=1024

# PostgreSQL / pgvector
PGVECTOR_DB_URL=jdbc:postgresql://127.0.0.1:5432/neopsyke_memory
PGVECTOR_DB_USER=neopsyke
PGVECTOR_DB_PASSWORD=neopsyke_dev
MEMORY_DEFAULT_NAMESPACE=neopsyke

# Local Docker bootstrap
PGVECTOR_BOOTSTRAP_MODE=auto
PGVECTOR_BOOTSTRAP_DOCKER_IMAGE=pgvector/pgvector:pg17
PGVECTOR_BOOTSTRAP_CONTAINER_NAME=neopsyke-pgvector-memory-db
PGVECTOR_BOOTSTRAP_VOLUME_NAME=neopsyke-pgvector-memory-data
PGVECTOR_BOOTSTRAP_STARTUP_TIMEOUT_MS=45000
